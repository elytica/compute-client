{
    "name": "elytica/compute-client",
    "description": "PHP implementation for the elytica Compute API.",
    "type": "library",
    "keywords": [
        "elytica",
        "integer-programming"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ruan Luies",
            "email": "ruan@elytica.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.5.0",
        "ratchet/pawl": "^0.4.1",
        "react/http": "^1.5.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Elytica\\ComputeClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elytica\\ComputeClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elytica\\ComputeClient\\ComputeClientServiceProvider"
            ]
        }
    }
}
